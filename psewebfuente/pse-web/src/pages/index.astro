---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';

const canonicalPath = '/';
---
<Base
  title="Previsión Social Empresarial para pymes | Ahorro fiscal y planes de empleo"
  description="Consultoría de previsión social empresarial para pymes: convierta la protección de su plantilla en ahorro fiscal. Guía completa y calculadora del plan de pensiones de empleo."
  canonicalPath={canonicalPath}
>
  <Hero
    kicker="Consultoría para pymes"
    h1="La previsión social de su empresa, bien planteada, ahorra impuestos"
    subtitulo="Ayudamos a gerentes y directores financieros de pymes a usar la previsión social empresarial como palanca fiscal, sin dejar de cuidar a su plantilla."
  />

  <div class="grid-2" style="margin-top:24px">
    <a class="card hub" href="/prevision-social-empresarial/">
      <span class="tag">Guía</span>
      <h2>Previsión Social Empresarial 2026</h2>
      <p>La guía fiscal completa para pymes: qué herramientas existen y cómo reducen su factura con Hacienda.</p>
      <span class="hub-link">Leer la guía →</span>
    </a>
    <a class="card hub" href="/plan-pensiones-empleo-pymes/">
      <span class="tag">Herramienta</span>
      <h2>Plan de Pensiones de Empleo</h2>
      <p>Deducciones, reducción de cotizaciones y una calculadora para estimar el ahorro de su empresa en 60 segundos.</p>
      <span class="hub-link">Calcular mi ahorro →</span>
    </a>
  </div>

  <style>
    .hub { text-decoration: none; color: inherit; display: block; }
    .hub:hover { border-color: var(--brand); }
    .hub h2 { margin: 10px 0 6px; }
    .hub p { color: var(--muted); }
    .hub-link { font-weight: 650; color: var(--brand); }
  </style>
</Base>
