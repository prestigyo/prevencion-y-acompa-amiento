---
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import TarjetaCluster from '../../components/TarjetaCluster.astro';
import data from '../../data/pilar-prevision-social-empresarial.json';

const site = Astro.site ?? new URL('https://PENDIENTE-DOMINIO.es');
const abs = (path) => new URL(path, site).href;

// --- JSON-LD: Article + BreadcrumbList ---
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.hero.h1,
  description: data.seo.description,
  inLanguage: 'es-ES',
  mainEntityOfPage: abs(data.seo.canonicalPath),
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: data.breadcrumb.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.nombre,
    item: abs(b.url),
  })),
};
---
<Base
  title={data.seo.title}
  description={data.seo.description}
  canonicalPath={data.seo.canonicalPath}
  ogTitle={data.seo.ogTitle}
  ogDescription={data.seo.ogDescription}
  jsonld={[articleSchema, breadcrumbSchema]}
>
  <nav class="crumbs" aria-label="Migas de pan">
    {data.breadcrumb.map((b, i) => (
      i < data.breadcrumb.length - 1
        ? <>{<a href={b.url}>{b.nombre}</a>}<span>/</span></>
        : <strong>{b.nombre}</strong>
    ))}
  </nav>

  <Hero kicker={data.hero.kicker} h1={data.hero.h1} subtitulo={data.hero.subtitulo} cta={data.hero.cta} />

  <div class="prose">
    {data.intro.map((p) => <p>{p}</p>)}
  </div>

  {data.secciones.map((s) => (
    s.enlace
      ? <TarjetaCluster h2={s.h2} parrafos={s.parrafos} enlace={s.enlace} />
      : (
        <section class="prose" id={s.id}>
          <h2>{s.h2}</h2>
          {s.parrafos.map((p) => <p>{p}</p>)}
        </section>
      )
  ))}

  <section class="cta-band" aria-labelledby="cta-int">
    <h3 id="cta-int">{data.ctaIntermedio.titulo}</h3>
    <p>{data.ctaIntermedio.texto}</p>
    <a class="btn" href={data.ctaIntermedio.boton.url}>{data.ctaIntermedio.boton.texto}</a>
  </section>

  <section class="prose" aria-labelledby="cluster-conv">
    <h2 id="cluster-conv">{data.clusterConvenio.titulo}</h2>
    <p>{data.clusterConvenio.texto}</p>
    <ul>
      {data.clusterConvenio.enlaces.map((e) => (
        <li>{e.publicada ? <a href={e.url}>{e.nombre}</a> : <span>{e.nombre} · <em>próximamente</em></span>}</li>
      ))}
    </ul>
  </section>

  <section class="cta-band" aria-labelledby="cta-fin">
    <h3 id="cta-fin">{data.ctaFinal.titulo}</h3>
    <p>{data.ctaFinal.texto}</p>
    <a class="btn" href={data.ctaFinal.boton.url}>{data.ctaFinal.boton.texto}</a>
  </section>
</Base>
