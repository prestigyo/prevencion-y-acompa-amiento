---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
---
<Base
  title="Gracias | Previsión Social Empresarial"
  description="Hemos recibido su solicitud."
  canonicalPath="/gracias/"
  robots="noindex,follow"
>
  <Hero
    kicker="Solicitud recibida"
    h1="Gracias, hemos recibido su solicitud"
    subtitulo="Un consultor revisará sus datos y le hará llegar el informe fiscal personalizado. Mientras tanto, puede seguir explorando la guía."
    cta={{ texto: 'Volver a la guía', url: '/prevision-social-empresarial/' }}
  />
</Base>
