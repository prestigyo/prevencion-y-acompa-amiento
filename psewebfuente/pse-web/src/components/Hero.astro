---
const { kicker, h1, subtitulo, cta } = Astro.props;
---
<section class="hero">
  {kicker && <p class="kicker">{kicker}</p>}
  <h1>{h1}</h1>
  {subtitulo && <p class="lede">{subtitulo}</p>}
  {cta && (
    <p style="margin-top:22px">
      <a class="btn" href={cta.url}>{cta.texto}</a>
    </p>
  )}
</section>
