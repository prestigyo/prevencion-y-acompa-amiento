---
/**
 * Tres datos de impacto. Los valores llegan como [PENDIENTE-DATO] hasta que el
 * consultor los rellene con la fuente oficial (Seguridad Social / INVERCO / INE).
 */
const { items = [] } = Astro.props;
---
<section class="grid-3" aria-label="Datos de impacto">
  {items.map((it) => (
    <div class="card stat">
      <div class="stat-num">{it.dato}</div>
      <p class="stat-lbl">{it.etiqueta}</p>
      {it.fuente ? <p class="stat-src">Fuente: {it.fuente}</p> : <p class="stat-src pend">Fuente pendiente</p>}
    </div>
  ))}
</section>

<style>
  .stat { text-align: center; }
  .stat-num { font-family: var(--serif); font-weight: 700; font-size: clamp(26px, 4vw, 38px); color: var(--brand); }
  .stat-lbl { color: var(--muted); font-size: 15px; margin: 8px 0 6px; }
  .stat-src { font-size: 12px; color: var(--muted2); margin: 0; }
  .stat-src.pend { font-style: italic; }
</style>
