---
/**
 * Isla interactiva: calculadora de ahorro fiscal del PPE.
 * El cálculo vive en src/lib/calculadoraPPE.js (función pura con tests).
 * La hidratación es diferida: el JS se inicializa cuando el bloque entra en
 * viewport (IntersectionObserver), para no penalizar el primer render.
 */
const { titulo, subtitulo, disclaimer, defaults = {} } = Astro.props;
const d = { n: 10, salario: 24000, aportEmpresa: 1500, tipoIS: 'general', ...defaults };
---
<section id="calculadora" class="calc card" aria-labelledby="calc-h">
  <h2 id="calc-h">{titulo}</h2>
  {subtitulo && <p class="lede" style="margin-top:0">{subtitulo}</p>}

  <div class="calc-grid">
    <form class="calc-inputs" id="calcForm" novalidate>
      <label>Empleados que se adhieren al plan
        <span class="hint" id="outN">{d.n}</span>
        <input type="range" name="n" min="1" max="250" step="1" value={d.n} />
      </label>

      <label>Salario bruto medio anual
        <span class="hint" id="outSalario">{d.salario} €</span>
        <input type="number" name="salario" min="0" step="500" value={d.salario} inputmode="numeric" />
      </label>

      <label>Aportación anual de la empresa por empleado
        <span class="hint" id="outAport">{d.aportEmpresa} €</span>
        <input type="range" name="aportEmpresa" min="0" max="8500" step="100" value={d.aportEmpresa} />
      </label>

      <label>Tipo del Impuesto de Sociedades
        <select name="tipoIS">
          <option value="general" selected={d.tipoIS === 'general'}>25 % general</option>
          <option value="micropyme" selected={d.tipoIS === 'micropyme'}>23 % microempresa</option>
          <option value="nuevaCreacion" selected={d.tipoIS === 'nuevaCreacion'}>15 % nueva creación</option>
        </select>
      </label>
    </form>

    <div class="calc-result" aria-live="polite" id="calcResult">
      <div class="rtotal">
        <span class="rtotal-lbl">Ahorro fiscal estimado el primer año</span>
        <span class="rtotal-num" id="rTotal">—</span>
        <span class="rtotal-sub" id="rFrase"></span>
      </div>
      <ul class="rbreak">
        <li><span>Deducción como gasto (base IS)</span><b id="rGasto">—</b></li>
        <li><span>Deducción en cuota del IS (10 %)</span><b id="rCuota">—</b></li>
        <li><span>Reducción de cotizaciones (SS)</span><b id="rSS">—</b></li>
      </ul>
      <p class="rinfo" id="rEmpleado"></p>
      <button class="btn" type="button" id="calcCta">Recibir mi informe fiscal personalizado</button>
      <p class="rdisc">{disclaimer}</p>
    </div>
  </div>
</section>

<script>
  import { calcularAhorroPPE, TIPOS_IS } from '../lib/calculadoraPPE.js';

  const eur = (n) => new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);

  function init() {
    const form = document.getElementById('calcForm');
    if (!form || form.dataset.ready) return;
    form.dataset.ready = '1';

    const el = (id) => document.getElementById(id);
    const outN = el('outN'), outSalario = el('outSalario'), outAport = el('outAport');

    function leer() {
      const fd = new FormData(form);
      return {
        n: Number(fd.get('n')),
        salario: Number(fd.get('salario')),
        aportEmpresa: Number(fd.get('aportEmpresa')),
        tipoISKey: String(fd.get('tipoIS')),
      };
    }

    function render() {
      const v = leer();
      const tipoIS = TIPOS_IS[v.tipoISKey] ?? TIPOS_IS.general;
      const r = calcularAhorroPPE({ n: v.n, salario: v.salario, aportEmpresa: v.aportEmpresa, tipoIS });

      outN.textContent = `${v.n}`;
      outSalario.textContent = eur(v.salario);
      outAport.textContent = eur(v.aportEmpresa);

      el('rTotal').textContent = eur(r.ahorroTotalEmpresa);
      el('rGasto').textContent = eur(r.ahorroGasto);
      el('rCuota').textContent = eur(r.deduccionCuota);
      el('rSS').textContent = eur(r.reduccionSS);
      el('rFrase').textContent = r.aportacionTotalEmpresa > 0
        ? `Su empresa recuperaría el ${Math.round(r.porcRecuperacion)} % de lo aportado vía ahorro fiscal el primer año.`
        : '';
      el('rEmpleado').textContent = v.aportEmpresa > 0
        ? `Además, cada empleado podría aportar por su cuenta hasta ${eur(r.aportMaxEmpleado)} más al año (límite conjunto empresa + trabajador: ${eur(r.limiteConjunto)}).`
        : '';

      // Contexto para el lead: rellena el campo oculto del formulario si existe.
      const hidden = document.getElementById('lead-simulacion');
      if (hidden) hidden.value = JSON.stringify({ ...v, ahorroTotal: r.ahorroTotalEmpresa });
    }

    form.addEventListener('input', render);
    el('calcCta').addEventListener('click', () => {
      render();
      document.getElementById('contacto')?.scrollIntoView({ behavior: 'smooth' });
    });
    render();
  }

  // Hidratación diferida al entrar en viewport.
  const anchor = document.getElementById('calculadora');
  if ('IntersectionObserver' in window && anchor) {
    const io = new IntersectionObserver((entries, obs) => {
      if (entries.some((e) => e.isIntersecting)) { init(); obs.disconnect(); }
    }, { rootMargin: '200px' });
    io.observe(anchor);
  } else {
    init();
  }
</script>

<style>
  .calc { margin: 30px 0; }
  .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; margin-top: 18px; }
  @media (max-width: 820px) { .calc-grid { grid-template-columns: 1fr; } }
  .calc-inputs label { display: block; font-size: 14px; font-weight: 600; margin-bottom: 18px; position: relative; }
  .calc-inputs .hint { float: right; font-weight: 700; color: var(--brand); }
  .calc-inputs input[type=range] { width: 100%; margin-top: 12px; accent-color: var(--brand); }
  .calc-inputs input[type=number], .calc-inputs select { width: 100%; margin-top: 8px; background: var(--bg); border: 1.5px solid var(--line); border-radius: 10px; color: var(--ink); font-size: 15px; padding: 11px 13px; font-family: var(--font); font-weight: 400; }
  .calc-result { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 20px; }
  .rtotal { text-align: center; padding-bottom: 14px; border-bottom: 1px solid var(--line); }
  .rtotal-lbl { display: block; font-size: 13px; color: var(--muted); }
  .rtotal-num { display: block; font-family: var(--serif); font-weight: 700; font-size: clamp(30px, 6vw, 46px); color: var(--brand); margin: 4px 0; }
  .rtotal-sub { display: block; font-size: 13.5px; color: var(--muted); }
  .rbreak { list-style: none; margin: 14px 0; padding: 0; }
  .rbreak li { display: flex; justify-content: space-between; gap: 12px; padding: 8px 0; border-bottom: 1px dashed var(--line); font-size: 14.5px; }
  .rbreak li span { color: var(--muted); }
  .rbreak b { font-variant-numeric: tabular-nums; }
  .rinfo { font-size: 13px; color: var(--muted); margin: 6px 0 14px; }
  .calc-result .btn { width: 100%; }
  .rdisc { font-size: 11.5px; color: var(--muted2); margin: 12px 0 0; line-height: 1.5; }
</style>
