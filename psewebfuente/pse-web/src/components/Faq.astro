---
/**
 * Bloque de preguntas frecuentes (visual). El schema FAQPage se genera en la
 * página a partir del mismo array y se inyecta vía el layout Base.
 * Usa <details>/<summary> nativos: accesible y sin JS.
 */
const { titulo = 'Preguntas frecuentes', faqs = [] } = Astro.props;
---
<section class="faq" aria-labelledby="faq-h">
  <h2 id="faq-h">{titulo}</h2>
  <div class="faq-list">
    {faqs.map((f) => (
      <details>
        <summary>{f.pregunta}</summary>
        <div class="faq-a">
          <p>{f.respuesta}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  .faq { margin: 34px 0; }
  .faq-list { display: grid; gap: 10px; margin-top: 16px; }
  details { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
  summary { cursor: pointer; padding: 15px 18px; font-weight: 650; list-style: none; position: relative; padding-right: 44px; }
  summary::-webkit-details-marker { display: none; }
  summary::after { content: "+"; position: absolute; right: 18px; top: 50%; transform: translateY(-50%); font-size: 22px; color: var(--brand); font-weight: 400; }
  details[open] summary::after { content: "–"; }
  .faq-a { padding: 0 18px 16px; color: var(--muted); }
  .faq-a p { margin: 0; }
</style>
